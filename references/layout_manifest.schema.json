{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Deck Layout Manifest",
  "type": "object",
  "required": ["pages"],
  "properties": {
    "pages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["page_id"],
        "properties": {
          "page_id": { "type": "string", "pattern": "^slide_[0-9]{2,}$" },
          "archetype": { "type": "string" },
          "main_group": {
            "type": "object",
            "properties": {
              "center_x": { "type": "number" },
              "expected_center_x": { "type": "number" },
              "tolerance": { "type": "number" }
            },
            "additionalProperties": true
          },
          "occupancy": {
            "type": "object",
            "properties": {
              "ratio": { "type": "number" },
              "min": { "type": "number" },
              "max": { "type": "number" }
            },
            "additionalProperties": true
          },
          "alignment_groups": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "axis": { "type": "string" },
                "label": { "type": "string" },
                "tolerance": { "type": "number" },
                "coordinates": {
                  "type": "array",
                  "items": { "type": "number" }
                }
              },
              "additionalProperties": true
            }
          },
          "connectors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "label": { "type": "string" },
                "tolerance": { "type": "number" },
                "start": { "type": "object", "additionalProperties": true },
                "end": { "type": "object", "additionalProperties": true },
                "from_anchor": { "type": "object", "additionalProperties": true },
                "to_anchor": { "type": "object", "additionalProperties": true }
              },
              "additionalProperties": true
            }
          },
          "cards": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string" },
                "label": { "type": "string" },
                "height": { "type": "number" },
                "min_height": { "type": "number" },
                "max_height": { "type": "number" }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
