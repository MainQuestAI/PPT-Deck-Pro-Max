{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Customer Visible Copy",
  "type": "object",
  "required": ["pages"],
  "properties": {
    "pages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["page_id", "title", "body", "insight", "speaker_script"],
        "properties": {
          "page_id": { "type": "string", "pattern": "^slide_[0-9]{2,}$" },
          "title": { "type": "string" },
          "body": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "array",
                "items": { "type": "string" }
              }
            ]
          },
          "insight": { "type": "string" },
          "speaker_script": { "type": "string" }
        },
        "propertyNames": {
          "not": {
            "enum": [
              "production_note",
              "layout_note",
              "agent_trace",
              "review_note",
              "prompt_meta",
              "batch_id",
              "prompt_id",
              "generation_status"
            ]
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
