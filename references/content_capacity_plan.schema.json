{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Deck Content Capacity Plan",
  "type": "object",
  "properties": {
    "target_pages": { "type": ["integer", "number", "string", "null"] },
    "planned_pages": { "type": ["integer", "number", "string", "null"] },
    "requested_pages": { "type": ["integer", "number", "string", "null"] },
    "recommended_pages": { "type": ["integer", "number", "string", "null"] },
    "recommended_page_count": { "type": ["integer", "number", "string", "null"] },
    "max_supported_pages": { "type": ["integer", "number", "string", "null"] },
    "supported_pages": { "type": ["integer", "number", "string", "null"] },
    "capacity_pages": { "type": ["integer", "number", "string", "null"] },
    "recommended_max_pages": { "type": ["integer", "number", "string", "null"] },
    "page_budget": {
      "type": "object",
      "additionalProperties": true
    },
    "budget_tiers": {
      "type": "object",
      "properties": {
        "conservative": { "$ref": "#/$defs/budgetTier" },
        "recommended": { "$ref": "#/$defs/budgetTier" },
        "extended": { "$ref": "#/$defs/budgetTier" },
        "appendix_heavy": { "$ref": "#/$defs/budgetTier" }
      },
      "additionalProperties": { "$ref": "#/$defs/budgetTier" }
    },
    "deck": {
      "type": "object",
      "additionalProperties": true
    },
    "notes": { "type": "string" }
  },
  "additionalProperties": true,
  "$defs": {
    "budgetTier": {
      "type": "object",
      "properties": {
        "pages": { "type": ["integer", "number", "string", "null"] },
        "page_count": { "type": ["integer", "number", "string", "null"] },
        "total_pages": { "type": ["integer", "number", "string", "null"] },
        "core_pages": { "type": ["integer", "number", "string", "null"] },
        "proof_pages": { "type": ["integer", "number", "string", "null"] },
        "extension_pages": { "type": ["integer", "number", "string", "null"] },
        "appendix_pages": { "type": ["integer", "number", "string", "null"] },
        "required_inputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "needs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "supplemental_info": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  }
}
