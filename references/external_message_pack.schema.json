{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "External Message Pack",
  "type": "object",
  "required": ["pages"],
  "properties": {
    "pages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["page_id", "business_problem", "customer_relevance", "allowed_claims", "evidence_refs", "visual_refs"],
        "properties": {
          "page_id": { "type": "string", "pattern": "^slide_[0-9]{2,}$" },
          "business_problem": { "type": "string" },
          "customer_relevance": { "type": "string" },
          "allowed_claims": {
            "type": "array",
            "items": { "type": "string" }
          },
          "evidence_refs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "visual_refs": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
