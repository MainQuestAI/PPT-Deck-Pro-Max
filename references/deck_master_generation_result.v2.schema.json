{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deck-master.local/contracts/generation-result.v2.schema.json",
  "title": "Deck Master Generation Result v2",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "session_id",
    "task_id",
    "page_id",
    "producer",
    "status",
    "source_fingerprint",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "deck_generation_result.v2"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!\\.{1,2}$)[^/\\\\]+$"
    },
    "page_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!\\.{1,2}$)[^/\\\\]+$"
    },
    "producer": {
      "type": "object",
      "required": [
        "capability",
        "version",
        "source_ref"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "completed",
        "partial",
        "failed"
      ]
    },
    "source_fingerprint": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact"
      },
      "minItems": 1
    },
    "preview": {
      "$ref": "#/$defs/artifact"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "enum": [
              "completed",
              "partial"
            ]
          }
        }
      },
      "then": {
        "required": [
          "artifacts",
          "preview"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "failed"
          }
        }
      },
      "then": {
        "required": [
          "errors"
        ],
        "properties": {
          "errors": {
            "minItems": 1
          }
        }
      }
    }
  ],
  "$defs": {
    "artifact": {
      "type": "object",
      "required": [
        "artifact_id",
        "kind",
        "path",
        "media_type",
        "sha256",
        "bytes",
        "validation_status"
      ],
      "properties": {
        "artifact_id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "page_html",
            "html_fragment",
            "page_svg",
            "page_png",
            "page_jpeg",
            "page_pptx",
            "deck_html",
            "deck_pdf",
            "deck_pptx",
            "asset_bundle",
            "quality_report",
            "source_snapshot"
          ]
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "not": {
            "pattern": "^(?:/|[A-Za-z]:\\\\)|(?:^|/)\\.\\.(?:/|$)"
          }
        },
        "media_type": {
          "type": "string"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "bytes": {
          "type": "integer",
          "minimum": 1
        },
        "validation_status": {
          "type": "string",
          "enum": [
            "validated",
            "invalid",
            "unvalidated",
            "stale",
            "missing"
          ]
        },
        "editability": {
          "type": "string",
          "enum": [
            "native",
            "hybrid",
            "flat_image",
            "not_applicable",
            "unknown"
          ]
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
