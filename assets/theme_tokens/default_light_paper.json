      "size": 11
    },
    "diagnostic-card": {
      "background": "#f8fbff",
      "border": "#d6e3f0"
    },
    "metric-chip": {
      "background": "rgba(47,128,255,0.10)",
      "border": "rgba(47,128,255,0.22)"
    }
