{
  "theme": "default-light-paper",
  "colors": {
    "background": "#f5f8fc",
    "surface": "#ffffff",
    "surface_border": "#d9e4f0",
    "text_primary": "#0a3553",
    "text_secondary": "#506b83",
    "accent": "#2f80ff",
    "positive": "#14b889",
    "warning": "#ff9d5c"
  },
  "typography": {
    "title_font": "Plus Jakarta Sans",
